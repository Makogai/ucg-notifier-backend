{
  "name": "ucg-notifier",
  "version": "1.0.0",
  "description": "UCG notifier backend (scrape + REST API)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/scraperWorker.js",
    "start:schedule:posts-only": "node dist/jobs/schedulerPostsOnly.js",
    "start:all": "sh scripts/start-all-prod.sh",
    "start:pm2": "pm2-runtime start ecosystem.config.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "seed:fix-table-names": "node scripts/fix-seed-table-names.mjs",
    "db:post-stats": "tsx scripts/post-stats.ts",
    "db:posts-by-faculty": "tsx scripts/posts-by-faculty.ts",
    "db:programs-by-faculty": "tsx scripts/programs-by-faculty.ts",
    "db:faculty-staff-stats": "tsx scripts/faculty-staff-stats.ts",
    "test:extract-posts-list-url": "tsx scripts/test-extract-posts-list-url.ts",
    "test:extract-faculty-posts-list-url": "tsx scripts/test-extract-faculty-posts-list-url.ts",
    "test:parse-faculty-staff-page": "tsx scripts/test-parse-faculty-staff-page.ts",
    "test:parse-professor-page": "tsx scripts/test-parse-professor-page.ts",
    "check:professor-biography": "tsx scripts/check-professor-biography.ts",
    "check:professor-teachings": "tsx scripts/check-professor-teachings-subjects.ts",
    "check:professor-selected-publications": "tsx scripts/check-professor-selected-publications.ts",
    "check:professor-avatar": "tsx scripts/check-professor-avatar.ts",
    "check:subject-semesters": "tsx scripts/check-subject-semesters-for-program.ts",
    "check:program-url": "tsx scripts/check-program-url.ts",
    "debug:subject-pagination": "tsx scripts/debug-subject-pagination.ts",
    "debug:subjects-sem9-10": "tsx scripts/debug-subjects-sem9-10.ts",
    "debug:scrape-subjects-program": "tsx scripts/debug-scrape-subjects-program.ts",
    "verify:queue": "tsx scripts/verify-queue.ts",
    "schedule": "tsx src/jobs/scheduler.ts",
    "schedule:posts-only": "tsx src/jobs/schedulerPostsOnly.ts",
    "schedule:posts-only:enqueue-once": "tsx -e \"import { scrapingQueue } from './src/jobs/queues'; (async()=>{ await scrapingQueue.waitUntilReady(); const job=await scrapingQueue.add('scrapePosts', {}, { attempts: 3, removeOnComplete: true }); console.log('enqueued scrapePosts jobId=', job.id); await scrapingQueue.close(); })();\"",
    "scrape:run-once": "tsx src/jobs/runOnce.ts",
    "scrape:posts-only:once": "tsx src/jobs/runScrapePostsOnly.ts",
    "scrape:faculty-staff:once": "tsx src/jobs/runFacultyStaffScrapeOnly.ts",
    "scrape:professor-details:once": "tsx src/jobs/runProfessorDetailsScrapeOnly.ts",
    "scrape:test:etf:faculties-programs": "tsx src/jobs/runEtfFacultiesPrograms.ts",
    "scrape:test:etf:subjects": "tsx src/jobs/runEtfSubjects.ts",
    "scrape:test:etf:faculty-posts": "tsx src/jobs/runEtfFacultyPosts.ts",
    "scrape:init": "tsx src/jobs/runInitScrape.ts",
    "worker": "tsx src/workers/scraperWorker.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bullmq": "^5.71.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.1",
    "mysql2": "^3.20.0",
    "pm2": "^6.0.14",
    "prisma": "^7.5.0",
    "puppeteer": "^24.40.0",
    "swagger-ui-express": "^5.0.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "typescript": "^5.9.3"
  }
}
