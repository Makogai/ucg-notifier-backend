PORT=3000

# Prisma / MySQL
DATABASE_URL="mysql://root:@localhost:3306/ucg_notifier"

# BullMQ / Redis (use `{ url: ... }` in code — see src/jobs/queues.ts)
# Example managed Redis: redis://default:PASSWORD@HOSTNAME:6379/0
# If the password contains @ or other reserved URL chars, URL-encode them (e.g. @ → %40).
REDIS_URL="redis://127.0.0.1:6379"

# Scraper
SCRAPER_BASE_URL="https://ucg.ac.me"
SCRAPER_SCHEDULE_EVERY_MINUTES=10
SCRAPER_PUPPETEER_HEADLESS=true
SCRAPER_PUPPETEER_TIMEOUT_MS=30000

# For quick testing, scrape only one faculty (set empty to disable).
SCRAPER_TEST_FACULTY_SHORTCODE=

# For quick testing, scrape only one professor by profileUrl.
# Example: https://ucg.ac.me/radnik/130329-budimir-lutovac
SCRAPER_TEST_PROFILE_URL=

# When `SCRAPER_TEST_PROFILE_URL` is not set, limits how many professors
# with missing biographyHtml will be scraped in one run.
SCRAPER_PROFILE_DETAILS_LIMIT=20

# Posts scraping mode:
# - PROGRAM_LEVEL: scrape posts per Program page
# - FACULTY_LEVEL: scrape posts once per Faculty page and map program/subject from cards
SCRAPER_POSTS_MODE=FACULTY_LEVEL

# When > 0, limits parsed posts per faculty/program scrape (testing). 0 or unset = all posts.
SCRAPER_TEST_POSTS_LIMIT=0

# Firebase Admin (FCM push) — pick ONE:
#
# A) File (simplest locally): download service account JSON from Firebase console → e.g. serviceaccount.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# B) Inline JSON: must be exactly ONE physical line in this file. PEM newlines in JSON are \n (backslash-n), not real line breaks.
#    In .env, wrap in single quotes so # and = inside the JSON don’t break parsing:
#    FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"…","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE…\n-----END PRIVATE KEY-----\n",…}'
#
#    Coolify / Docker: paste minified JSON as the secret value — first character should be { — no extra outer "quotes".
FIREBASE_SERVICE_ACCOUNT_JSON=

# Simple auth for admin endpoints (required).
ADMIN_API_KEY="change-me"

# DB seed (prisma db seed) — loads SQL from project root
# Seed multiple SQL files (comma-separated, relative to project root).
# Example incremental setup:
# SEED_SQL_FILES=seed-data.sql,seed-faculty-staff.sql
# Back-compat (single file):
# SEED_SKIP=true
# SEED_SQL_FILE=seed-data.sql

